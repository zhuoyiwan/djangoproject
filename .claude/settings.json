{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/Users/zhuoyiwan/Code/django/.claude/bin/post_backend_write.py\"",
            "timeout": 120,
            "statusMessage": "Running backend checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/Users/zhuoyiwan/Code/django/.claude/bin/auto_finish_backend.py\"",
            "timeout": 1800,
            "statusMessage": "Syncing, validating, and publishing backend work"
          }
        ]
      }
    ]
  }
}
