{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-0ff60525debfca230cc35f1a9d4246f455731619e9e5427444f4d0dc90844d0e",
    "ANTHROPIC_BASE_URL": "http://49.235.100.131:4000",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gpt-5.4",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "gpt-5.4",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gpt-5.4",
    "ANTHROPIC_MODEL": "gpt-5.4",
    "ANTHROPIC_REASONING_MODEL": "gpt-5.4",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "gpt-5.4",
  "teammateMode": "in-process",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/bin/post_backend_write.py\"",
            "timeout": 120,
            "statusMessage": "Running backend checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/bin/auto_finish_backend.py\"",
            "timeout": 1800,
            "statusMessage": "Syncing, validating, and publishing backend work"
          }
        ]
      }
    ]
  }
}
